{
    "name": "lumera/lumera-frontiers",
    "description": "Lumera Frontiers - Modern Publisher Platform for Journal Management Framework Workflow and Publishing",
    "type": "project",
    "license": "GPL-3.0-only",
    "keywords": [
        "lumera",
        "publishing",
        "journal",
        "open-access"
    ],
    "homepage": "https://lumera.sangia.org/",
    "support": {
        "issues": "https://github.com/mokesano/lumera-frontiers/issues",
        "forum": "https://forum.lumera.sangia.org/",
        "source": "https://github.com/mokesano/lumera-frontiers"
    },
    "authors": [
        {
            "name": "Rochmady",
            "email": "rochmady@sangia.org",
            "role": "Lead Developer"
        },
        {
            "name": "Susiana",
            "email": "susiana@sangia.org",
            "role": "Co-Lead Developer"
        },
        {
            "name": "Khayra Salsabila",
            "email": "khayra@sangia.org",
            "role": "Developer"
        },
        {
            "name": "Rakha Ibrahim Rochmady",
            "email": "rakha.im@sangia.org",
            "role": "Senior Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "adodb/adodb-php": "^5.22",
        "chillerlan/php-qrcode": "^6.0",
        "ezyang/htmlpurifier": "^4.19",
        "guzzlehttp/guzzle": "^7.0",
        "midtrans/midtrans-php": "^2.6",
        "mpdf/mpdf": "^8.0",
        "setasign/fpdi": "^2.0",
        "simplepie/simplepie": "^1.9",
        "smarty/smarty": "^5.8",
        "symfony/polyfill-mbstring": "^1.36",
        "symfony/var-dumper": "^6.0",
        "vlucas/phpdotenv": "^5.5",
        "wikimedia/less.php": "^5.5",
        "wizdam/debug-toolbar": "^1.0",
        "xendit/xendit-php": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Lumera\\Modules\\": [
                "core/Modules/"
            ],
            "Lumera\\Kernel\\": [
                "core/Kernel/"
            ],
            "Lumera\\Core\\": [
                "core/Includes/"
            ],
            "App\\Domain\\": [
                "app/Domain/"
            ],
            "App\\Pages\\": [
                "app/Pages/"
            ],
            "App\\Controllers\\": [
                "app/Controllers/"
            ],
            "App\\Services\\": [
                "app/Services/"
            ],
            "App\\Helpers\\": [
                "app/Helpers/"
            ]
        },
        "files": [
            "core/Includes/functions.php"
        ],
        "exclude-from-classmap": [
            "**/node_modules/",
            "**/tests/",
            "**/*.inc.php",
            "**/*_BAK",
            "**/*_WIZDAM",
            "core/Modules/cliTool/CliTool.php",
            "core/Modules/xml/XMLParser.php",
            "core/Modules/rt/RTStruct.php",
            "core/Modules/recaptcha/recaptchalib.php",
            "core/Modules/json/JSON.php",
            "core/Modules/oai/OAIStruct.php",
            "core/Modules/tools/install.php",
            "core/Modules/tools/generateIdentifiers.php",
            "core/Modules/tools/deleteSubmissions.php",
            "core/Modules/tools/copyAccessLogFileTool.php",
            "core/Modules/tools/upgrade.php",
            "core/Modules/tools/migrateInvoices.php",
            "core/Modules/mail/EmailTemplate.php",
            "core/Modules/cache/MemcacheCache.php",
            "core/Modules/cache/APCuCache.php",
            "core/Modules/cache/GenericCache.php",
            "core/Kernel/CoreProfiler.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Lumera\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "vendor-dir": "core/Library"
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"echo 'Lumera Frontiers Platform installed successfully!\\n';\""
        ],
        "post-update-cmd": [
            "@php -r \"echo 'Lumera Frontiers Platform updated successfully!\\n';\""
        ],
        "test": "phpunit",
        "cs-check": "@php scripts/cs-check.php",
        "cs-fix": "phpcbf --standard=PSR12 core/Library app",
        "analyze": "phpstan analyse --level max core/Library app"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "wizdam-debug-toolbar",
            "type": "vcs",
            "url": "https://github.com/mokesano/DebugToolbar"
        }
    ]
}
