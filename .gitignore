# Lumera Frontiers .gitignore

# PHP compiled files
*.phpc

# Abaikan seluruh isi storage/cache/ kecuali .gitkeep di folder inti
storage/cache/*
!storage/cache/t_cache/.gitkeep
!storage/cache/t_compile/.gitkeep
!storage/cache/t_config/.gitkeep
**/cache/*
!**/cache/.gitkeep

# Abaikan semua file .json.gz di seluruh repositori
*.json.gz
*.gz
*.cache

# Dependencies
vendor/
core/Libraries/
core/Library/
node_modules/

# Compiled and build artifacts
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Cache directories
.cache/
__pycache__/
*.pyc
*.pyo
.Python
